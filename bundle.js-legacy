  { id: "yearly",  name: "Yearly",  price: 59.99,period: "/an",   highlight: false, features: [
      "Tout dans Pro",
      "2 mois offerts",
      "Badge Chrome Pro",
      "Accès anticipé aux nouvelles features",
  ]},
];

function PremiumScreen(props) {
  var useState = React.useState;
  var [selected, setSelected] = useState("plus");

  return React.createElement("div", {
    style: { minHeight: "100vh", background: CM.bg, paddingBottom: 120 }
  },
    /* Header */
    React.createElement(CmHeader, {
      left: React.createElement(CmIconBtn, { onClick: props.onBack }, Cmi.back),
      onLogoTap: props.onThemeOpen,
    }),

    /* Hero */
    React.createElement("div", {
      style: {
        margin: "8px 22px 22px",
        padding: "26px 22px",
        borderRadius: 20,
        background: "linear-gradient(135deg, " + CM.primary + ", " + CM.primaryDark + ")",
        color: CM.onPrimary,
        textAlign: "center",
        boxShadow: CM.shadowGlow,
      }
    },
      React.createElement("div", { style: { fontSize: 40, marginBottom: 8 } }, "💎"),
      React.createElement("h2", {
        style: { margin: 0, fontSize: 24, fontWeight: 800, letterSpacing: "-0.3px" }
      }, "Chrome Premium"),
      React.createElement("p", {
        style: { margin: "8px 0 0", fontSize: 13, opacity: 0.92 }
      }, "Debloque les themes, les jeux et bien plus.")
    ),

    /* Plans */
    React.createElement("div", { style: { padding: "0 22px", display: "flex", flexDirection: "column", gap: 12 } },
      CM_PLANS.map(function(plan) {
        var active = selected === plan.id;
        return React.createElement("div", {
          key: plan.id,
          onClick: function(){ setSelected(plan.id); },
          style: {
            position: "relative",
            padding: 18, borderRadius: 16, cursor: "pointer",
            background: active ? CM.primaryFaint : CM.surface,
            border: "2px solid " + (active ? CM.primary : CM.line),
            transition: "all 0.15s",
          }
        },
          plan.highlight && React.createElement("div", {
            style: {
              position: "absolute", top: -10, right: 16,
              padding: "3px 10px", borderRadius: 100,
              background: CM.primary, color: CM.onPrimary,
              fontSize: 10, fontWeight: 800, letterSpacing: "0.05em", textTransform: "uppercase",
            }
          }, "Populaire"),
          React.createElement("div", {
            style: { display: "flex", alignItems: "center", justifyContent: "space-between", marginBottom: 12 }
          },
            React.createElement("div", null,
              React.createElement("div", { style: { fontSize: 16, fontWeight: 800, color: CM.title } }, plan.name),
              plan.price > 0 && React.createElement("div", { style: { marginTop: 4 } },
                React.createElement("span", { style: { fontSize: 22, fontWeight: 800, color: CM.title } }, plan.price.toFixed(2) + " €"),
                React.createElement("span", { style: { fontSize: 13, color: CM.sub, marginLeft: 4 } }, plan.period)
              ),
              plan.price === 0 && React.createElement("div", { style: { fontSize: 14, color: CM.sub, marginTop: 4 } }, "Toujours gratuit")
            ),
            active && React.createElement("div", {
              style: {
                width: 30, height: 30, borderRadius: "50%",
                background: CM.primary, color: CM.onPrimary,
                display: "flex", alignItems: "center", justifyContent: "center",
              }
            }, Cmi.check)
          ),
          React.createElement("ul", { style: { margin: 0, paddingLeft: 0, listStyle: "none", display: "flex", flexDirection: "column", gap: 6 } },
            plan.features.map(function(f, i) {
              return React.createElement("li", {
                key: i,
                style: { display: "flex", alignItems: "flex-start", gap: 8, fontSize: 13, color: CM.body }
              },
                React.createElement("span", { style: { color: CM.primary, display: "inline-flex", marginTop: 2 } }, Cmi.check2),
                f
              );
            })
          )
        );
      })
    ),

    /* Stickers caméléon premium */
    React.createElement("div", {
      style: {
        margin: "22px 22px 0", padding: 18, borderRadius: 16,
        background: CM.surface2, display: "flex", alignItems: "center", gap: 14,
      }
    },
      React.createElement("div", { style: { display: "flex", gap: 4 } },
        React.createElement(ChameleonLogo, { size: 40, color: "#30D79C", showBg: false }),
        React.createElement(ChameleonLogo, { size: 40, color: "#FF8A4C", showBg: false }),
        React.createElement(ChameleonLogo, { size: 40, color: "#A855F7", showBg: false })
      ),
      React.createElement("div", { style: { flex: 1 } },
        React.createElement("div", { style: { fontSize: 14, fontWeight: 800, color: CM.title } }, "Stickers caméléon"),
        React.createElement("div", { style: { fontSize: 12, color: CM.sub, marginTop: 2 } }, "Un pack exclusif à l'effigie du caméléon dans toutes les couleurs.")
      )
    ),

    /* CTA */
    React.createElement("div", {
      style: {
        position: "fixed", bottom: 0, left: 0, right: 0,
        maxWidth: 480, margin: "0 auto",
        padding: "16px 22px", background: CM.bg,
        borderTop: "1px solid " + CM.line,
        paddingBottom: "calc(16px + env(safe-area-inset-bottom))",
      }
    },
      React.createElement(CmBtn, {
        variant: "primary", size: "lg", fullWidth: true,
        onClick: function(){ cmToast("Paiement simule — " + CM_PLANS.find(function(p){return p.id===selected;}).name + " active !", "info"); },
      }, selected === "free" ? "Continuer gratuitement" : "💎 Passer a " + CM_PLANS.find(function(p){return p.id===selected;}).name)
    )
  );
}


/* ══════ js/screens-events.js ══════ */
/* Chrome Messenger — Événements (Pro)
 * Create/send invitations to contact categories with QR code + date/time + location + photo.
 * Invitations are pinned at the top of each recipient's conversation until event date.
 * Reminders fire J-1 and J-day (local notification stub).
 */

const CM_EVENT_TYPES = [
  { id: "anniversaire", label: "Anniversaire", emoji: "🎂" },
  { id: "deuil",        label: "Deuil",        emoji: "🕊️" },
  { id: "mariage",      label: "Mariage",      emoji: "💍" },
  { id: "reunion",      label: "Réunion",      emoji: "👥" },
  { id: "fete",         label: "Fête",         emoji: "🎉" },
  { id: "autre",        label: "Autre",        emoji: "📌" },
];

/* === Storage === */
function cmGetEvents() { return cmLoad("cm_events", []); }
function cmSetEvents(list) { cmSave("cm_events", list); }
function cmAddEvent(ev) {
  var list = cmGetEvents();
  ev.id = ev.id || ("ev_" + Date.now() + "_" + Math.random().toString(36).substring(2,6));
  list.push(ev);
  cmSetEvents(list);
  return ev.id;
}
function cmRemoveEvent(id) {
  cmSetEvents(cmGetEvents().filter(function(e){ return e.id !== id; }));
}
/* Event pinned to a conversation = the recipient sees it at top */
function cmEventForConversation(convId) {
  var contacts = cmGetContacts();
  var conv = cmFindConversation(convId);
  if (!conv || conv.type !== "direct") return null;
  var contactId = conv.contactId;
  var now = Date.now();
  return cmGetEvents().find(function(ev) {
    if (!ev.recipients) return false;
    if (ev.recipients.indexOf(contactId) === -1 && ev.recipients.indexOf("*") === -1) return false;
    /* Show invitation up to event day end */
    return ev.dateMs >= now - 24*3600*1000;
  }) || null;
}

/* === QR Code generator — simple SVG pattern deterministic from seed === */
function cmGenerateQrSvg(seed, size) {
  size = size || 140;
  var grid = 21; /* 21x21 pseudo-QR */
  var cell = size / grid;
  var hash = 0;
  for (var i = 0; i < seed.length; i++) hash = ((hash << 5) - hash) + seed.charCodeAt(i);
  var rects = [];
  for (var y = 0; y < grid; y++) {
    for (var x = 0; x < grid; x++) {
      /* Locator corners (finder patterns) like real QR */
      var corner =
        (x < 7 && y < 7) || (x >= grid-7 && y < 7) || (x < 7 && y >= grid-7);
      if (corner) {
        var inOuter = (x === 0 || x === 6 || y === 0 || y === 6) ||
                      (x === grid-7 || x === grid-1 || y === 0 || y === 6) ||
                      (x === 0 || x === 6 || y === grid-7 || y === grid-1);
        var inInner = (x >= 2 && x <= 4 && y >= 2 && y <= 4) ||
                      (x >= grid-5 && x <= grid-3 && y >= 2 && y <= 4) ||
                      (x >= 2 && x <= 4 && y >= grid-5 && y <= grid-3);
        if (inOuter || inInner) rects.push({x:x,y:y});
        continue;
      }
      /* Deterministic noise */
      var bit = (Math.abs(hash ^ (x * 73856093) ^ (y * 19349663)) % 100) < 48;
      if (bit) rects.push({x:x,y:y});
    }
  }
  return React.createElement("svg", {
    width: size, height: size, viewBox: "0 0 " + size + " " + size,
    style: { display: "block", background: "white", borderRadius: 8 }
  },
    rects.map(function(r, i) {
      return React.createElement("rect", {
        key: i, x: r.x * cell, y: r.y * cell, width: cell, height: cell, fill: "#111"
      });
    })
  );
}

/* === Events List Screen === */
function EventsScreen(props) {
  var events = cmGetEvents().sort(function(a,b){ return a.dateMs - b.dateMs; });
  var now = Date.now();

  return React.createElement("div", { style: { minHeight: "100vh", background: CM.bg, paddingBottom: 40 } },
    React.createElement(CmHeader, {
      title: "Événements",
      left: React.createElement(CmIconBtn, { onClick: props.onBack }, Cmi.back),
      right: React.createElement(CmIconBtn, { onClick: props.onCreate, label: "new event" }, Cmi.plus),
    }),

    React.createElement("div", { style: { padding: "0 22px" } },
      events.length === 0 ? React.createElement("div", {
        style: { padding: 40, textAlign: "center", color: CM.sub, fontSize: 14 }
      },
        React.createElement("div", { style: { fontSize: 48, marginBottom: 8 } }, "🎉"),
        "Aucun événement pour le moment.",
        React.createElement("br"),
        "Appuie sur ", React.createElement("b", null, "+"), " pour créer."
      ) : events.map(function(ev) {
        var isPast = ev.dateMs < now - 24*3600*1000;
        var dateStr = new Date(ev.dateMs).toLocaleDateString("fr-FR", { weekday:"long", day:"numeric", month:"long" });
        var typ = CM_EVENT_TYPES.find(function(t){ return t.id === ev.type; }) || CM_EVENT_TYPES[5];
        return React.createElement("div", {
          key: ev.id,
          onClick: function(){ props.onOpen(ev.id); },
          style: {
            padding: 14, borderRadius: 14, marginBottom: 10,
            background: CM.surface, border: "1px solid " + CM.line,
            display: "flex", alignItems: "center", gap: 12,
            opacity: isPast ? 0.6 : 1, cursor: "pointer",
          }
        },
          React.createElement("div", { style: { fontSize: 28 } }, typ.emoji),
          React.createElement("div", { style: { flex: 1 } },
            React.createElement("div", { style: { fontSize: 15, fontWeight: 800, color: CM.title } }, ev.title || typ.label),
            React.createElement("div", { style: { fontSize: 12, color: CM.sub, marginTop: 2 } }, dateStr + " · " + ev.time),
            ev.place && React.createElement("div", { style: { fontSize: 11, color: CM.muted, marginTop: 2 } }, "📍 " + ev.place)
          ),
          React.createElement("span", { style: { color: CM.muted } }, Cmi.chevR)
        );
      })
    )
  );
}

/* === Event Creator === */
function EventCreator(props) {
  var useState = React.useState;
  var [type, setType] = useState("anniversaire");
  var [title, setTitle] = useState("");
  var [msg, setMsg]     = useState("");
  var [date, setDate]   = useState("");  /* YYYY-MM-DD */
  var [time, setTime]   = useState("18:00");
  var [place, setPlace] = useState("");
  var [photo, setPhoto] = useState("");
  var [cats, setCats]   = useState({ all: true });

  var contacts = cmGetContacts();

  function toggleCat(cid) {
    var next = Object.assign({}, cats);
    if (cid === "all") { setCats({ all: !cats.all }); return; }
    next.all = false;
    next[cid] = !next[cid];
    setCats(next);
  }

  function recipientsFromCats() {
    if (cats.all) return ["*"];
    var ids = [];
    contacts.forEach(function(c){ if (c.category && cats[c.category]) ids.push(c.id); });
    return ids;
  }

  function save() {
    if (!title.trim() || !date) { cmToast("Titre et date requis", "warn"); return; }
    var dateMs = new Date(date + "T" + (time || "18:00")).getTime();
    var recipients = recipientsFromCats();
    var evId = cmAddEvent({
      type: type, title: title.trim(), message: msg.trim(),
      dateMs: dateMs, time: time, place: place.trim(), photo: photo,
      recipients: recipients, createdAt: Date.now(),
    });
    /* Schedule local reminder stubs (stored as pending notifs — the app loop can pick them up) */
    cmAddNotif({ id:"n_"+Date.now(), kind:"event", evId: evId, label: title + " (demain)", at: dateMs - 24*3600*1000 });
    cmAddNotif({ id:"n_"+(Date.now()+1), kind:"event", evId: evId, label: title + " (aujourd'hui)", at: dateMs });
    cmToast("Invitation envoyée à " + (recipients[0] === "*" ? "tous" : recipients.length + " contact(s)"), "success");
    props.onDone();
  }

  return React.createElement("div", { style: { minHeight: "100vh", background: CM.bg, paddingBottom: 40 } },
    React.createElement(CmHeader, {
      title: "Nouvelle invitation",
      left: React.createElement(CmIconBtn, { onClick: props.onBack }, Cmi.back),
    }),

    React.createElement("div", { style: { padding: "0 22px" } },
      /* Type */
      React.createElement("div", { style: { display: "flex", gap: 8, overflowX: "auto", marginBottom: 14, paddingBottom: 4 } },
        CM_EVENT_TYPES.map(function(t){
          var active = type === t.id;
          return React.createElement("button", {
            key: t.id, onClick: function(){ setType(t.id); },
            style: {
              flexShrink: 0, padding: "10px 14px", borderRadius: 12,
              background: active ? CM.primarySoft : CM.surface,
              border: "1px solid " + (active ? CM.primary : CM.line),
              color: active ? CM.primaryDark : CM.body,
              fontFamily: "inherit", fontWeight: 700, fontSize: 13, cursor: "pointer",
              display: "flex", alignItems: "center", gap: 6,
            }
          }, React.createElement("span", null, t.emoji), t.label);
        })
      ),
      /* Title */
      React.createElement("input", {
        value: title, onChange: function(e){ setTitle(e.target.value); },
        placeholder: "Titre de l'événement", autoFocus: true,
        style: inputSt()
      }),
      /* Message */
      React.createElement("textarea", {
        value: msg, onChange: function(e){ setMsg(e.target.value); },
        placeholder: "Message d'invitation",
        rows: 3, style: Object.assign({}, inputSt(), { resize: "vertical" })
      }),
      /* Photo URL (stub) */
      React.createElement("input", {
        value: photo, onChange: function(e){ setPhoto(e.target.value); },
        placeholder: "Photo (URL ou laisser vide)",
        style: inputSt()
      }),
      /* Date + Time */
      React.createElement("div", { style: { display: "grid", gridTemplateColumns: "2fr 1fr", gap: 10 } },
        React.createElement("input", {
          type: "date", value: date, onChange: function(e){ setDate(e.target.value); },
          style: inputSt()
        }),
        React.createElement("input", {
          type: "time", value: time, onChange: function(e){ setTime(e.target.value); },
          style: inputSt()
        })
      ),
      /* Place */
      React.createElement("input", {
        value: place, onChange: function(e){ setPlace(e.target.value); },
        placeholder: "Localisation",
        style: inputSt()
      }),

      /* Destinataires (catégories) */
      React.createElement("h3", {
        style: { margin: "18px 4px 10px", fontSize: 12, fontWeight: 700, color: CM.muted, textTransform: "uppercase", letterSpacing: "0.08em" }
      }, "Envoyer à"),
      React.createElement("div", { style: { display: "flex", flexWrap: "wrap", gap: 8, marginBottom: 20 } },
        CM_CONTACT_CATEGORIES.map(function(cat) {
          var active = cats[cat.id];
          var count = cat.id === "all" ? contacts.length : contacts.filter(function(c){ return c.category === cat.id; }).length;
          return React.createElement("button", {
            key: cat.id, onClick: function(){ toggleCat(cat.id); },
            style: {
              padding: "10px 14px", borderRadius: 12,
              background: active ? CM.primary : CM.surface,
              border: "1px solid " + (active ? CM.primary : CM.line),
              color: active ? CM.onPrimary : CM.body,
              fontFamily: "inherit", fontWeight: 700, fontSize: 13, cursor: "pointer",
              display: "flex", alignItems: "center", gap: 6,
            }
          }, React.createElement("span", null, cat.emoji), cat.label, React.createElement("span", {
            style: { opacity: 0.7, fontSize: 11 }
          }, "(" + count + ")"));
        })
      ),

      React.createElement(CmBtn, { variant: "primary", size: "lg", fullWidth: true, onClick: save },
        "🎫 Envoyer l'invitation")
    )
  );
}

function inputSt() {
  return {
    width: "100%", padding: 14, borderRadius: 12,
    border: "1px solid " + CM.line, background: CM.surface, color: CM.title,
    fontSize: 15, fontFamily: "inherit", marginBottom: 10, boxSizing: "border-box",
  };
}

/* === Event Detail (shows invitation card with QR) === */
function EventDetail(props) {
  var events = cmGetEvents();
  var ev = events.find(function(e){ return e.id === props.eventId; });
  if (!ev) return null;

  var dateStr = new Date(ev.dateMs).toLocaleDateString("fr-FR", { weekday:"long", day:"numeric", month:"long", year:"numeric" });
  var typ = CM_EVENT_TYPES.find(function(t){ return t.id === ev.type; }) || CM_EVENT_TYPES[5];
  var qrPayload = "cm:event:" + ev.id;

  return React.createElement("div", { style: { minHeight: "100vh", background: CM.bg, paddingBottom: 40 } },
    React.createElement(CmHeader, {
      title: "Invitation",
      left: React.createElement(CmIconBtn, { onClick: props.onBack }, Cmi.back),
      right: React.createElement(CmIconBtn, {
        onClick: function(){ if(confirm("Supprimer cet événement ?")){ cmRemoveEvent(ev.id); props.onBack(); } },
        label: "delete"
      }, Cmi.trash),
    }),

    /* Invitation card */
    React.createElement("div", {
      style: {
        margin: "8px 22px 22px", padding: 22, borderRadius: 20,
        background: "linear-gradient(135deg, " + CM.primary + ", " + CM.primaryDark + ")",
        color: CM.onPrimary, textAlign: "center",
        boxShadow: CM.shadowGlow,
      }
    },
      React.createElement("div", { style: { fontSize: 42, marginBottom: 4 } }, typ.emoji),
      React.createElement("div", { style: { fontSize: 12, fontWeight: 700, opacity: 0.85, textTransform: "uppercase", letterSpacing: "0.1em" } }, typ.label),
      React.createElement("h2", { style: { margin: "6px 0 12px", fontSize: 22, fontWeight: 800 } }, ev.title),
      ev.message && React.createElement("p", { style: { margin: "0 0 16px", fontSize: 14, opacity: 0.95 } }, ev.message),
      ev.photo && React.createElement("div", {
        style: { width: 140, height: 140, borderRadius: 12, background: "#fff", margin: "0 auto 16px", overflow: "hidden" }
      },
        React.createElement("img", { src: ev.photo, alt: "photo", style: { width: "100%", height: "100%", objectFit: "cover" } })
      ),

      /* QR Code */
      React.createElement("div", {
        style: {
          width: 150, height: 150, margin: "0 auto 14px",
          padding: 5, background: "white", borderRadius: 12,
        }
      }, cmGenerateQrSvg(qrPayload, 140)),
      React.createElement("div", { style: { fontSize: 11, opacity: 0.8 } }, "Scanne ce code pour confirmer"),

      /* Infos */
      React.createElement("div", {
        style: {
          marginTop: 18, padding: 14, background: "rgba(255,255,255,0.15)",
          borderRadius: 12, textAlign: "left",
        }
      },
        React.createElement("div", { style: { display: "flex", alignItems: "center", gap: 10, marginBottom: 6 } },
          React.createElement("span", null, "📅"),
          React.createElement("span", { style: { fontSize: 13, fontWeight: 600 } }, dateStr)
        ),
        React.createElement("div", { style: { display: "flex", alignItems: "center", gap: 10, marginBottom: 6 } },
          React.createElement("span", null, "🕒"),
          React.createElement("span", { style: { fontSize: 13, fontWeight: 600 } }, ev.time)
        ),
        ev.place && React.createElement("div", { style: { display: "flex", alignItems: "center", gap: 10 } },
          React.createElement("span", null, "📍"),
          React.createElement("span", { style: { fontSize: 13, fontWeight: 600 } }, ev.place)
        )
      )
    ),

    /* Recipients */
    React.createElement("div", { style: { padding: "0 22px" } },
      React.createElement("h3", {
        style: { margin: "0 4px 10px", fontSize: 12, fontWeight: 700, color: CM.muted, textTransform: "uppercase", letterSpacing: "0.08em" }
      }, "Envoyée à"),
      React.createElement("div", {
        style: { padding: 14, borderRadius: 14, background: CM.surface, border: "1px solid " + CM.line, fontSize: 13, color: CM.body }
      },
        (ev.recipients && ev.recipients[0] === "*") ? "Tous les contacts" :
        ((ev.recipients || []).length + " contact(s) sélectionné(s)")
      )
    )
  );
}

/* === QR Scanner === */
function QrScannerScreen(props) {
  var useState = React.useState;
  var [manual, setManual] = useState("");

  function submit() {
    if (!manual.trim()) return;
    if (manual.indexOf("cm:event:") === 0) {
      var evId = manual.slice(9);
      var ev = cmGetEvents().find(function(e){ return e.id === evId; });
      if (ev) {
        cmToast("Invitation trouvée : " + ev.title, "success");
        props.onEvent(evId);
      } else {
        cmToast("Événement introuvable", "warn");
      }
    } else {
      cmToast("QR non reconnu", "warn");
    }
  }

  return React.createElement("div", { style: { minHeight: "100vh", background: CM.bg, paddingBottom: 40 } },
    React.createElement(CmHeader, {
      title: "Scanner QR",
      left: React.createElement(CmIconBtn, { onClick: props.onBack }, Cmi.back),
    }),

    /* Camera viewfinder stub */
    React.createElement("div", {
      style: {
        margin: "0 22px 18px", padding: 40, borderRadius: 20,
        background: CM.surface2, textAlign: "center",
        border: "2px dashed " + CM.line2,
      }
    },
      React.createElement("div", { style: { fontSize: 56, marginBottom: 12 } }, "📷"),
      React.createElement("div", { style: { fontSize: 14, color: CM.sub } }, "Pointe l'appareil photo vers le QR code"),
      React.createElement("div", { style: { fontSize: 12, color: CM.muted, marginTop: 6 } }, "(Démo : saisie manuelle ci-dessous)")
    ),

    React.createElement("div", { style: { padding: "0 22px" } },
      React.createElement("h3", {
        style: { margin: "0 4px 10px", fontSize: 12, fontWeight: 700, color: CM.muted, textTransform: "uppercase", letterSpacing: "0.08em" }
      }, "Saisie manuelle"),
      React.createElement("input", {
        value: manual, onChange: function(e){ setManual(e.target.value); },
        placeholder: "cm:event:...",
        style: inputSt()
      }),
      React.createElement(CmBtn, { variant: "primary", size: "lg", fullWidth: true, onClick: submit }, "Vérifier le code")
    )
  );
}


/* ══════ js/screens-settings.js ══════ */
/* Chrome Messenger — Settings / Drawer */

function SettingsScreen(props) {
  var useState = React.useState;
  var [, force] = useState(0);
  var profile = cmGetProfile();
  var settings = cmGetSettings();

  function toggle(k) {
    settings[k] = !settings[k];
    cmSetSettings(settings);
    force(Date.now());
  }

  return React.createElement("div", {
    style: { minHeight: "100vh", background: CM.bg, paddingBottom: 60 }
  },
    React.createElement(CmHeader, {
      onLogoTap: props.onThemeOpen,
      left: React.createElement(CmIconBtn, { onClick: props.onBack }, Cmi.back),
    }),

    /* Profile card */
    React.createElement("div", {
      onClick: props.onEditProfile,
      style: {
        margin: "6px 22px 22px",
        padding: "18px",
        borderRadius: 18,
        background: CM.surface,
        border: "1px solid " + CM.line,
        display: "flex", alignItems: "center", gap: 14,
        cursor: "pointer",
      }
    },
      React.createElement(CmAvatar, { name: profile.name || "?", size: 60 }),
      React.createElement("div", { style: { flex: 1 } },
        React.createElement("div", { style: { fontSize: 18, fontWeight: 800, color: CM.title } }, profile.name || "—"),
        React.createElement("div", { style: { fontSize: 13, color: CM.sub, marginTop: 3 } }, profile.phone || "—"),
        profile.bio && React.createElement("div", { style: { fontSize: 12, color: CM.muted, marginTop: 3 } }, profile.bio)
      ),
      React.createElement("span", { style: { color: CM.muted } }, Cmi.chevR)
    ),

    /* Settings sections — style WhatsApp/Telegram */
    React.createElement("div", { style: { padding: "0 22px" } },

      /* Apparence */
      sectionHeading("Apparence"),
      row(Cmi.heart, cm("themes"), CM.themeName || "Menthe", props.onThemeOpen),
      (function(){
        var activeLang = CM_LANGS.find(function(l){ return l.code === _cmLang; }) || CM_LANGS[0];
        return row("🌐", cm("language") || "Langue", activeLang.name, props.onLangOpen);
      })(),

      /* Confidentialité & Sécurité (E2E) */
      sectionHeading("Confidentialité & Sécurité"),
      row("🔒", "Chiffrement de bout en bout", "Activé", null),
      toggleRow("👁️", "Confirmations de lecture", !!settings.readReceipts, function(){ toggle("readReceipts"); }),
      toggleRow("🕒", "Statut « vu à »", !!settings.lastSeen, function(){ toggle("lastSeen"); }),
      toggleRow("📸", "Photo de profil visible", !!settings.profilePhotoVisible, function(){ toggle("profilePhotoVisible"); }),
      row("🚫", "Contacts bloqués", (settings.blocked || []).length + " bloqué(s)", props.onBlocked),
      row("🔑", "Verrouillage par code", settings.appLock ? "Actif" : "Inactif", props.onAppLock),

      /* Notifications */
      sectionHeading(cm("notifications_s") || "Notifications"),
      toggleRow("🔔", "Notifications", !!settings.notifications, function(){ toggle("notifications"); }),
      toggleRow("🔊", "Sons", !!settings.sound, function(){ toggle("sound"); }),
      toggleRow("📳", "Vibration", !!settings.vibration, function(){ toggle("vibration"); }),
      toggleRow("📅", "Rappels tâches (J-1 & J)", !!settings.taskReminders, function(){ toggle("taskReminders"); }),
      toggleRow("🎉", "Rappels événements", !!settings.eventReminders, function(){ toggle("eventReminders"); }),

      /* Discussions */
      sectionHeading("Discussions"),
      toggleRow("⌨️", "Entrée pour envoyer", !!settings.enterToSend, function(){ toggle("enterToSend"); }),
      toggleRow("📥", "Téléchargement auto des médias", !!settings.autoDownload, function(){ toggle("autoDownload"); }),
      toggleRow("💾", "Sauvegarde cloud chiffrée", !!settings.cloudBackup, function(){ toggle("cloudBackup"); }),
      row("🎨", "Arrière-plan de chat", "Par défaut", null),
      row("🔤", "Taille du texte", "Moyenne", null),

      /* Stockage et données */
      sectionHeading("Stockage et données"),
      row("📊", "Utilisation du stockage", "— ", null),
      row("🌍", "Réseau", "Wi-Fi + Mobile", null),

      /* Comptes liés */
      sectionHeading("Comptes"),
      row("📱", "Appareils liés", "1 appareil actif", null),
      row("👤", "Compte", profile.phone || "—", props.onEditProfile),

      /* Aide */
      sectionHeading("Aide"),
      row("❓", "FAQ & Aide", null, null),
      row("📧", "Nous contacter", null, null),
      row("📜", "Conditions d'utilisation", null, null),
      row("🔐", "Politique de confidentialité", null, null),

      /* À propos */
      sectionHeading(cm("about") || "À propos"),
      row(Cmi.info, "Version", CM_VERSION),

      React.createElement("button", {
        onClick: function(){
          if (confirm(cm("resetConfirm"))) { cmResetAll(); location.reload(); }
        },
        style: {
          marginTop: 16, width: "100%", padding: "14px",
          background: "transparent", border: "1px solid #FF4757",
          color: "#FF4757", borderRadius: 14,
          fontFamily: "inherit", fontWeight: 700, cursor: "pointer",
        }
      }, cm("resetData"))
    )
  );
}

/* === LANGUAGE SCREEN — page dédiée avec toutes les langues en natif === */
function LanguageScreen(props) {
  var useState = React.useState;
  var [, force] = useState(0);
  var [search, setSearch] = useState("");
  var q = search.toLowerCase();

  var filtered = CM_LANGS.filter(function(l) {
    if (!q) return true;
    return l.name.toLowerCase().indexOf(q) !== -1 || l.nameFr.toLowerCase().indexOf(q) !== -1 || l.code.indexOf(q) !== -1;
  });

  return React.createElement("div", {
    style: { minHeight: "100vh", background: CM.bg, paddingBottom: 40 }
  },
    React.createElement(CmHeader, {
      title: "Langue",
      left: React.createElement(CmIconBtn, { onClick: props.onBack }, Cmi.back),
    }),
    React.createElement("div", { style: { padding: "0 22px 12px" } },
      React.createElement("input", {
        value: search, onChange: function(e){ setSearch(e.target.value); },
        placeholder: "Rechercher une langue…",
        style: {
          width: "100%", padding: "12px 14px", borderRadius: 14,
          background: CM.surface2, border: "none",
          color: CM.title, fontSize: 14, fontFamily: "inherit",
        }
      })
    ),
    React.createElement("div", { style: { padding: "0 22px", display: "flex", flexDirection: "column", gap: 6 } },
      filtered.map(function(lang) {
        var active = _cmLang === lang.code;
        return React.createElement("button", {
          key: lang.code,
          onClick: function(){
            cmSetLang(lang.code); force(Date.now());
            if (props.onLangChange) props.onLangChange();
          },
          style: {
            padding: "14px 16px", borderRadius: 14,
            background: active ? CM.primarySoft : CM.surface,
            border: "1px solid " + (active ? CM.primary : CM.line),
            display: "flex", alignItems: "center", gap: 14,
            cursor: "pointer", fontFamily: "inherit",
            width: "100%", textAlign: "left",
          }
        },
          React.createElement("span", { style: { fontSize: 22 } }, lang.flag),
          React.createElement("div", { style: { flex: 1 } },
            React.createElement("div", {
              style: { fontSize: 15, fontWeight: 700, color: active ? CM.primaryDark : CM.title }
            }, lang.name),
            React.createElement("div", {
              style: { fontSize: 12, color: CM.sub, marginTop: 2 }
            }, lang.nameFr)
          ),
          active && React.createElement("span", { style: { color: CM.primary, display: "inline-flex" } }, Cmi.check)
        );
      })
    )
  );
}

function sectionHeading(text) {
  return React.createElement("h3", {
    style: { margin: "18px 4px 10px", fontSize: 11, fontWeight: 700, color: CM.muted, textTransform: "uppercase", letterSpacing: "0.08em" }
  }, text);
}

function row(icon, label, value, onClick) {
  return React.createElement("div", {
    onClick: onClick,
    style: {
      padding: "12px 14px", borderRadius: 12,
      background: CM.surface, border: "1px solid " + CM.line,
      display: "flex", alignItems: "center", gap: 12,
      cursor: onClick ? "pointer" : "default", marginBottom: 6,
    }
  },
    icon && React.createElement("span", { style: { color: CM.body } }, icon),
    React.createElement("span", { style: { flex: 1, fontSize: 14, fontWeight: 600, color: CM.body } }, label),
    value && React.createElement("span", { style: { fontSize: 13, color: CM.sub } }, value),
    onClick && React.createElement("span", { style: { color: CM.muted } }, Cmi.chevR)
  );
}

function toggleRow(icon, label, on, onToggle) {
  return React.createElement("div", {
    onClick: onToggle,
    style: {
      padding: "12px 14px", borderRadius: 12,
      background: CM.surface, border: "1px solid " + CM.line,
      display: "flex", alignItems: "center", gap: 12,
      cursor: "pointer", marginBottom: 6,
    }
  },
    React.createElement("span", { style: { fontSize: 16 } }, icon),
    React.createElement("span", { style: { flex: 1, fontSize: 14, fontWeight: 600, color: CM.body } }, label),
    React.createElement("div", {
      style: {
        width: 40, height: 22, borderRadius: 100,
        background: on ? CM.primary : CM.line2, position: "relative", transition: "background 0.2s",
      }
    },
      React.createElement("div", {
        style: {
          position: "absolute", top: 3, left: on ? 21 : 3,
          width: 16, height: 16, borderRadius: "50%", background: "white",
          transition: "left 0.2s", boxShadow: "0 1px 2px rgba(0,0,0,0.25)",
        }
      })
    )
  );
}


/* ══════ js/app.js ══════ */
/* Chrome Messenger — Main App orchestrator */

function App() {
  var useState = React.useState;
  var useEffect = React.useEffect;
  var [onboarded, setOnboarded] = useState(cmIsOnboarded());
  var [view, setView] = useState("chat"); /* chat (home) | tasks | games | notifs */
  var [params, setParams] = useState({});
  var [, forceRender] = useState(0);

  useEffect(function(){
    /* Initialize crypto (non-blocking for UI) */
    cmCryptoInit().catch(function(e){ console.warn("[crypto] init failed", e); });
    /* Refresh seeds (stories expire after 24h) */
    cmSeedIfNeeded();
  }, []);

  function nav(v, p) {
    setView(v);
    setParams(p || {});
    window.scrollTo(0, 0);
  }

  if (!onboarded) {
    return React.createElement(OnboardingFlow, {
      onDone: function(){ setOnboarded(true); setView("chat"); }
    });
  }

  var handlers = {
    onOpenChat: function(id){ nav("conversation", { convId: id }); },
    onBack: function(){ nav("chat"); },
    onNewChat: function(){ cmToast(cm("newChat") + " (demo)", "info"); },
    onAddStory: function(){ nav("storyCreate"); },
    onViewStory: function(id){ nav("storyView", { storyId: id }); },
    onOpenPremium: function(){ nav("premium"); },
    onOpenMenu: function(){ nav("settings"); },
    onOpenSettings: function(){ nav("settings"); },
    onEditProfile: function(){ cmToast(cm("editProfile") + " (demo)", "info"); },
    onThemeChange: function(){ forceRender(Date.now()); },
    onLangChange: function(){ forceRender(Date.now()); },
    onChanged: function(){ forceRender(Date.now()); },
    onSeeAll: function(cat){ cmToast(cm("seeAll") + ": " + cat, "info"); },
    onPlayGame: function(g){
      if (g.kind === "external" && g.href) { window.open(g.href, "_blank"); return; }
      cmToast("🎮 " + g.name + " — " + cm("comingSoon"), "info");
    },
    onThemeOpen: function(){ forceRender(Date.now()); cmToast("Tape sur le cameleon !", "info"); },
    onLangOpen: function(){ nav("language"); },
    onOpenEvents: function(){ nav("events"); },
    onOpenQr: function(){ nav("qrScanner"); },
  };

  var screen;
  if (view === "chat") {
    screen = React.createElement(HomeScreen, Object.assign({}, handlers, {
      onThemeChange: handlers.onThemeChange,
    }));
  } else if (view === "tasks") {
    screen = React.createElement(TodolistScreen, handlers);
  } else if (view === "games") {
    screen = React.createElement(GamesScreen, handlers);
  } else if (view === "notifs") {
    screen = React.createElement(NotifsScreen, handlers);
  } else if (view === "conversation") {
    screen = React.createElement(ChatScreen, Object.assign({}, handlers, {
      convId: params.convId,
      onOpenEvent: function(id){ nav("eventDetail", { eventId: id }); },
    }));
  } else if (view === "premium") {
    screen = React.createElement(PremiumScreen, handlers);
  } else if (view === "settings") {
    screen = React.createElement(SettingsScreen, Object.assign({}, handlers, {
      onBack: function(){ nav("chat"); },
    }));
  } else if (view === "language") {
    screen = React.createElement(LanguageScreen, Object.assign({}, handlers, {
      onBack: function(){ nav("settings"); },
    }));
  } else if (view === "events") {
    screen = React.createElement(EventsScreen, Object.assign({}, handlers, {
      onBack: function(){ nav("tasks"); },
      onCreate: function(){ nav("eventCreate"); },
      onOpen: function(id){ nav("eventDetail", { eventId: id }); },
    }));
  } else if (view === "eventCreate") {
    screen = React.createElement(EventCreator, Object.assign({}, handlers, {
      onBack: function(){ nav("events"); },
      onDone: function(){ nav("events"); },
    }));
  } else if (view === "eventDetail") {
    screen = React.createElement(EventDetail, Object.assign({}, handlers, {
      eventId: params.eventId,
      onBack: function(){ nav("events"); },
    }));
  } else if (view === "qrScanner") {
    screen = React.createElement(QrScannerScreen, Object.assign({}, handlers, {
      onBack: function(){ nav("tasks"); },
      onEvent: function(id){ nav("eventDetail", { eventId: id }); },
    }));
  } else if (view === "storyView") {
    screen = React.createElement(StoryViewer, Object.assign({}, handlers, {
      storyId: params.storyId,
      onClose: function(){ nav("chat"); },
    }));
  } else if (view === "storyCreate") {
    screen = React.createElement(StoryCreator, Object.assign({}, handlers, {
      onClose: function(){ nav("chat"); },
      onDone: function(){ nav("chat"); },
    }));
  } else {
    screen = React.createElement("div", null, "404");
  }

  /* Hide bottom nav during fullscreen views */
  var hideNav = view === "conversation" || view === "storyView" || view === "storyCreate" || view === "premium" || view === "settings" || view === "language" || view === "events" || view === "eventCreate" || view === "eventDetail" || view === "qrScanner";

  var navItems = [
    { id: "chat",   label: cm("navChat"),   icon: view === "chat"   ? Cmi.chat  : Cmi.chat },
    { id: "tasks",  label: cm("navTasks"),  icon: Cmi.tasks, badge: false },
    { id: "games",  label: cm("navGames"),  icon: Cmi.games },
    { id: "notifs", label: cm("navNotifs"), icon: Cmi.bell, badge: cmUnreadNotifsCount() > 0 },
  ];

  /* Layout: flex column so nav bar sticks to bottom, screen fills remaining height */
  return React.createElement("div", {
    style: {
      maxWidth: 480, margin: "0 auto",
      minHeight: "100vh", height: "100vh",
      position: "relative",
      display: "flex", flexDirection: "column",
      overflow: "hidden",
    }
  },
    React.createElement("div", {
      style: { flex: 1, overflowY: "auto", overflowX: "hidden" }
    }, screen),
    !hideNav && React.createElement(CmBottomNav, {
      items: navItems, active: view, onNav: nav,
    })
  );
}


/* ══════ js/main.js ══════ */
/* Chrome Messenger — entry point */

(function() {
  /* Apply saved theme immediately, before React mounts */
  var savedTheme = localStorage.getItem(CM_KEYS.theme) || "mint";
  cmApplyTheme(savedTheme);

  var root = ReactDOM.createRoot(document.getElementById("root"));
  root.render(React.createElement(App));
})();

