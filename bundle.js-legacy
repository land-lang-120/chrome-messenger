const CM_LOGO_TRANSFORM = "translate(-158 -280)";

function ChameleonLogo(props) {
  var size = props.size || 36;
  var color = props.color || CM.primary;
  var showBg = props.showBg !== false; /* default true */
  /* In dark mode, the bg fill mirrors the surface so the "white rectangle" disappears */
  var isDark = CM.darkMode === true;
  var bgFill = props.bgFill || (isDark ? CM.bg : "#fefefe");
  var eyeFill = props.eyeFill || (isDark ? CM.bg : "#f8fcfa");

  var children = [];
  if (showBg) {
    children.push(React.createElement("path", { key:"bg", d: CM_LOGO_BG_PATH, fill: bgFill, transform: CM_LOGO_TRANSFORM }));
  }
  children.push(React.createElement("path", { key:"body", d: CM_LOGO_BODY_PATH, fill: color, transform: CM_LOGO_TRANSFORM }));
  children.push(React.createElement("path", { key:"eye",  d: CM_LOGO_EYE_PATH,  fill: color, transform: CM_LOGO_TRANSFORM }));
  children.push(React.createElement("path", { key:"hi",   d: CM_LOGO_EYE_HILITE_PATH, fill: eyeFill, transform: CM_LOGO_TRANSFORM }));

  return React.createElement("svg", {
    width: size, height: size,
    viewBox: "0 0 297 231",
    xmlns: "http://www.w3.org/2000/svg",
    style: Object.assign({ display: "block" }, props.style || {}),
    "aria-label": "Chrome Messenger",
  }, children);
}

