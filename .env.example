# Copier ce fichier en .env.local et remplir les valeurs reelles.
# NE JAMAIS commit le fichier .env.local.

# Firebase (client config publique — proteger via Firestore rules)
VITE_FB_API_KEY=
VITE_FB_AUTH_DOMAIN=
VITE_FB_PROJECT_ID=
VITE_FB_STORAGE_BUCKET=
VITE_FB_MESSAGING_ID=
VITE_FB_APP_ID=
VITE_FB_VAPID=

# Mode : 'dev' | 'staging' | 'prod'
VITE_APP_ENV=dev

# Feature flags
VITE_ENABLE_EMULATORS=true
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_CRASHLYTICS=false
